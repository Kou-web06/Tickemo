{
  "expo": {
    "name": "Tickemo",
    "slug": "Tickemo",
    "version": "2.2.3",
    "buildNumber": "19",
    "orientation": "portrait",
    "icon": "./assets/app-icon/icon1.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "10",
      "bundleIdentifier": "com.anonymous.Tickemo",
      "frameworks": [
        "MusicKit"
      ],
      "infoPlist": {
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "ライブの思い出を画像として保存するために、フォトライブラリへのアクセスが必要です。",
        "NSPhotoLibraryAddUsageDescription": "ライブの思い出を画像として保存するために、フォトライブラリへのアクセスが必要です。",
        "NSAppleMusicUsageDescription": "アーティストの楽曲を再生するために、Apple Musicへのアクセスが必要です。",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.177149194090-q3lsjb53p2bgls307mrsc5q3fkk2kbjt"
            ]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.icloud-services": [
          "CloudDocuments",
          "CloudKit"
        ],
        "com.apple.developer.icloud-container-identifiers": [
          "iCloud.com.anonymous.Tickemo"
        ],
        "com.apple.developer.ubiquity-container-identifiers": [
          "iCloud.com.anonymous.Tickemo"
        ],
        "com.apple.developer.ubiquity-kvstore-identifier": "$(TeamIdentifierPrefix)com.anonymous.Tickemo"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon/icon1.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "screenOrientation": "portrait",
      "package": "com.anonymous.Tickemo",
      "permissions": [
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "react-native-cloud-storage",
      "expo-font",
      "expo-file-system",
      [
        "expo-media-library",
        {
          "photosPermission": "ライブの思い出を画像として保存するために使用します。",
          "savePhotosPermission": "ライブの思い出を画像として保存するために使用します。"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "16.0"
          }
        }
      ],
      "expo-sqlite",
      "expo-localization"
    ],
