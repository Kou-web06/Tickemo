{
  "expo": {
    "name": "Tickemo",
    "slug": "Tickemo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon/icon1.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app-icon/icon1.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Tickemo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "ライブの思い出を画像として保存するために、フォトライブラリへのアクセスが必要です。",
        "NSPhotoLibraryAddUsageDescription": "ライブの思い出を画像として保存するために、フォトライブラリへのアクセスが必要です。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon/icon1.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Tickemo",
      "permissions": [
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "ライブの思い出を画像として保存するために使用します。",
          "savePhotosPermission": "ライブの思い出を画像として保存するために使用します。"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4179883a-5098-498d-9b2d-028149d2dfab"
      }
    }
  }
}
